{
  "expo": {
    "name": "Wanshitong",
    "slug": "wanshitong-mobile",
    "scheme": "wanshitong",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/51255307-c8fe-4304-a5cd-323c327aae2e",
      "requestHeaders": {
        "expo-channel-name": "production"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "art.tylermakes.wanshitong",
      "infoPlist": {
        "NSHealthShareUsageDescription": "This app reads your health data to track your activity.",
        "NSHealthUpdateUsageDescription": "This app writes workout data to HealthKit.",
        "NSCalendarsUsageDescription": "This app syncs events to your calendar.",
        "NSCalendarsFullAccessUsageDescription": "This app needs full calendar access to create and manage events."
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-calendar",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "This app reads your health data.",
          "NSHealthUpdateUsageDescription": "This app writes data to HealthKit.",
          "background": true
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://wanshitong.tylermakes.art/api/trpc",
      "auth0Domain": "dev-ahpx1ju0tyq2wgl7.us.auth0.com",
      "auth0ClientId": "NBztaOPRyyh4LJt5cBOQqj6jzD3DfFa9",
      "auth0Audience": "https://homebase-shared.tylermakes.art",
      "eas": {
        "projectId": "51255307-c8fe-4304-a5cd-323c327aae2e"
      },
      "router": {}
    },
    "owner": "tylerrsmith"
  }
}
